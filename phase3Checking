package courseProject;

public class CheckingAccount extends Account {

    public CheckingAccount() {
        setServiceFee(0.5);
        setInterestRate(2);
    }

    @Override
    public void deposit(double amount) {
        setBalance(getBalanceValue() + amount - getServiceFee());
    }

    @Override
    public void withdrawal(double amount) {
        double newBalance = getBalanceValue() - amount - getServiceFee();
        if (newBalance < 0) newBalance -= 30; // overdraft fee
        setBalance(newBalance);
    }

    @Override
    public double balance() {
        return getBalanceValue();
    }

    public void addInterest() {
        setBalance(getBalanceValue() + getBalanceValue() * getInterestRate() / 100);
    }
}
