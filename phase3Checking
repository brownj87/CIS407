package courseProject;

public class CheckingAccount extends Account {
    private static final double SERVICE_FEE = 0.5;
    private static final double OVERDRAFT_FEE = 30.0;
    private static final double INTEREST_RATE = 0.02;

    @Override
    public void deposit(double amount) {
        double total = getBalance() + amount - SERVICE_FEE;
        setBalance(total);
    }

    @Override
    public void withdrawal(double amount) {
        double total = getBalance() - amount - SERVICE_FEE;
        if (total < 0) total -= OVERDRAFT_FEE;
        setBalance(total);
    }

    @Override
    public double balance() {
        return getBalance();
    }

    public void addInterest() {
        setBalance(getBalance() + getBalance() * INTEREST_RATE);
    }
}
