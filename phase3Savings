package courseProject;

public class SavingsAccount extends Account {
    private static final double SERVICE_FEE = 0.25;
    private static final double INTEREST_RATE = 0.05;

    @Override
    public void deposit(double amount) {
        setBalance(getBalance() + amount - SERVICE_FEE);
    }

    @Override
    public void withdrawal(double amount) throws Exception {
        if (getBalance() - amount - SERVICE_FEE < 0)
            throw new Exception("Insufficient funds in Savings Account.");
        setBalance(getBalance() - amount - SERVICE_FEE);
    }

    @Override
    public double balance() {
        return getBalance();
    }

    public void addInterest() {
        setBalance(getBalance() + getBalance() * INTEREST_RATE);
    }
}
