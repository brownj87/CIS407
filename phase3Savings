package courseProject;

public class SavingsAccount extends Account {
    private final double TRANSACTION_FEE = 0.25;
    private final double INTEREST_RATE = 0.05; // 5%

    @Override
    public void deposit(double amount) throws Exception {
        if (amount <= 0) throw new Exception("Deposit must be positive.");
        setBalance(getBalance() + amount - TRANSACTION_FEE);
    }

    @Override
    public void withdrawal(double amount) throws Exception {
        if (amount <= 0) throw new Exception("Withdrawal must be positive.");
        if (amount + TRANSACTION_FEE > getBalance())
            throw new Exception("Insufficient funds. Savings cannot go negative.");
        setBalance(getBalance() - amount - TRANSACTION_FEE);
    }

    @Override
    public double balance() {
        return getBalance();
    }

    public void addInterest() {
        setBalance(getBalance() + getBalance() * INTEREST_RATE);
    }
}
