package courseProject;

public class SavingsAccount extends Account {
    private static final double SERVICE_FEE = 0.25;
    private static final double INTEREST_RATE = 0.05; // 5%

    @Override
    public void deposit(double amount) throws Exception {
        if (amount <= 0) throw new Exception("Invalid deposit amount.");
        setBalance(getBalance() + amount - SERVICE_FEE);
    }

    @Override
    public void withdrawal(double amount) throws Exception {
        if (amount <= 0) throw new Exception("Invalid withdrawal amount.");
        double newBalance = getBalance() - amount - SERVICE_FEE;
        if (newBalance < 0) throw new Exception("Insufficient funds. Withdrawal denied.");
        setBalance(newBalance);
    }

    @Override
    public double balance() {
        return getBalance() + getBalance() * INTEREST_RATE;
    }

    public double getInterestRate() {
        return INTEREST_RATE;
    }
}
