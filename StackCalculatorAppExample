import java.util.Scanner;
public class StackCalculatorApp {
    public static void main(String[] args) {

        StackCalculator calc = new StackCalculator();
        Scanner input = new Scanner(System.in);
        System.out.println("Welcome to the Stack Calculator.");
        System.out.println();
        System.out.println("Commands: push n, add, sub, mult, div, list, clear, or quit.");
        System.out.println();
        boolean running = true;
        while (running) {
            System.out.print("stack> ");
            String command = input.next();
            switch (command) {
                case "push":
                    if (input.hasNextDouble()) {
                        double value = input.nextDouble();
                        calc.push(value);
                        calc.listStack();
                    } else {
                        System.out.println("Unrecognized command.");
                        input.nextLine();
                    }
                    break;
                case "add":
                    if (calc.size() >= 2) {
                        double first = calc.pop();
                        double second = calc.pop();
                        calc.push(second + first);
                        calc.listStack();
                    } else {
                        System.out.println("Unrecognized command.");
                    }
                    break;
                case "sub":
                    if (calc.size() >= 2) {
                        double first = calc.pop();
                        double second = calc.pop();
                        calc.push(second - first);
                        calc.listStack();
                    } else {
                        System.out.println("Unrecognized command.");
                    }
                    break;
                case "mult":
                    if (calc.size() >= 2) {
                        double first = calc.pop();
                        double second = calc.pop();
                        calc.push(second * first);
                        calc.listStack();
                    } else {
                        System.out.println("Unrecognized command.");
                    }
                    break;
                case "div":
                    if (calc.size() >= 2) {
                        double first = calc.pop();
                        double second = calc.pop();
                        calc.push(second / first);
                        calc.listStack();
                    } else {
                        System.out.println("Unrecognized command.");
                    }
                    break;
                case "list":
                    calc.listStack();
                    break;
                case "clear":
                    calc.clearStack();
                    calc.listStack();
                    break;
                case "quit":
                    running = false;
                    System.out.println();
                    System.out.println("Thanks for using the Stack Calculator.");
                    break;
                default:
                    System.out.println("Unrecognized command.");
                    input.nextLine();
            }
        }
        input.close();
    }
}
